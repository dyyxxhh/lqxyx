{
  "name": "ying-zhong-jiu-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test:run": "vitest run",
    "build": "tsc --noEmit && vite build",
    "e2e": "playwright test",
    "serve:prod": "npm run build && node server/static-server.js",
    "start:prod": "node server/static-server.js",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "phaser": "4.1.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.2",
    "jsdom": "29.1.1",
    "serve": "14.2.6",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
